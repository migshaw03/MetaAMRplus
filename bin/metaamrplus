#!/usr/bin/env bash
set -euo pipefail

########################################
# MetaAMRplus v1.5.1 (Stable)
# Author: Misheck Shawa
########################################

VERSION="1.5.1"
COLOC_DIST=10000
MIN_CONTIG_LEN=200

show_banner() {
cat << EOF
========================================
 MetaAMRplus v${VERSION}
 AMR, Metal & Colocalisation Analysis
 Author: Misheck Shawa
========================================
EOF
}

########################################
# INPUT
########################################
if [[ $# -ne 1 ]]; then
    show_banner
    echo "ERROR: Provide genome FASTA"
    exit 1
fi

GENOME="$1"
[[ -f "$GENOME" ]] || { echo "ERROR: File not found: $GENOME"; exit 1; }

########################################
# PATHS
########################################
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RESULTS_DIR="${METAAMRPLUS_RESULTS:-$PWD/metaamrplus_results}"

########################################
# DB RESOLUTION
########################################
if [[ -n "${METAAMRPLUS_DB:-}" ]]; then
    DB_DIR="$METAAMRPLUS_DB"
elif [[ -n "${CONDA_PREFIX:-}" && -d "$CONDA_PREFIX/share/metaamrplus/db" ]]; then
    DB_DIR="$CONDA_PREFIX/share/metaamrplus/db"
else
    DB_DIR="$HOME/.metaamrplus/db"
fi

DB_PREFIX="$DB_DIR/MetaAMRplus_DB_v1.0"
IDMAP="$DB_DIR/MetaAMRplus_v1.0.idmap.tsv"

########################################
# DEPENDENCIES
########################################
for tool in prodigal blastp awk python3 sort grep; do
    command -v "$tool" >/dev/null 2>&1 || {
        echo "ERROR: Missing dependency: $tool"
        exit 1
    }
done

########################################
# DB CHECK
########################################
for ext in phr pin psq; do
    [[ -f "${DB_PREFIX}.${ext}" ]] || {
        echo "ERROR: Missing BLAST DB file: ${DB_PREFIX}.${ext}"
        exit 1
    }
done

[[ -f "$IDMAP" ]] || { echo "ERROR: Missing IDMAP: $IDMAP"; exit 1; }

########################################
# OUTPUT
########################################
PREFIX="$(basename "$GENOME")"
PREFIX="${PREFIX%.*}"
OUTDIR="$RESULTS_DIR/$PREFIX"
mkdir -p "$OUTDIR"

show_banner

########################################
# STEP 1
########################################
echo "[1/9] FASTA validation"
grep -q '^>' "$GENOME" || exit 1

########################################
# STEP 2
########################################
echo "[2/9] Filter contigs"

FILTERED_FASTA="$OUTDIR/${PREFIX}.filtered.fasta"

awk -v min="$MIN_CONTIG_LEN" '
/^>/ {
  if (seq && length(seq) >= min) {
    print header
    print seq
  }
  header=$0
  seq=""
  next
}
{ seq = seq $0 }
END {
  if (seq && length(seq) >= min) {
    print header
    print seq
  }
}
' "$GENOME" > "$FILTERED_FASTA"

########################################
# STEP 3
########################################
echo "[3/9] ORF prediction"

prodigal -i "$FILTERED_FASTA" \
  -a "$OUTDIR/${PREFIX}.proteins.faa" \
  -d "$OUTDIR/${PREFIX}.genes.fna" \
  -f gff \
  -o "$OUTDIR/${PREFIX}.gff" \
  -p meta >/dev/null 2>&1

########################################
# STEP 4
########################################
echo "[4/9] BLASTP"

blastp -query "$OUTDIR/${PREFIX}.proteins.faa" \
  -db "$DB_PREFIX" \
  -out "$OUTDIR/raw.tsv" \
  -evalue 1e-5 \
  -outfmt "6 qseqid sseqid pident length qlen evalue bitscore"

########################################
# STEP 5
########################################
echo "[5/9] Filtering hits"

awk '$3>=95 && ($4/$5)*100>=80' "$OUTDIR/raw.tsv" \
| sort -k1,1 -k7,7nr \
| awk '!seen[$1]++' \
> "$OUTDIR/filtered.tsv"

########################################
# STEP 6
########################################
echo "[6/9] Annotation"

python3 "$SCRIPT_DIR/annotate_metaamrplus.py" \
  "$OUTDIR/filtered.tsv" \
  "$IDMAP" \
  > "$OUTDIR/annotated.tsv"

grep -v -E '\t(gyrA|gyrB|parC|parE|rpoB|rpsL|rrs|folP|murA)\t' \
  "$OUTDIR/annotated.tsv" \
  > "$OUTDIR/acquired.tsv"

########################################
# STEP 7
########################################
echo "[7/9] Coordinates"

{
echo -e "query_protein\tmetaamrplus_id\tgene\ttype\tphenotype\tmechanism\tsource\tpident\tcoverage\tbitscore\tcontig\tstart\tend\tstrand"

awk -F'\t' -v OFS='\t' '
NR==FNR {
    if ($3=="CDS") {
        split($9, a, ";")
        for (i in a) {
            if (a[i] ~ /^ID=/) {
                id=a[i]
                sub(/^ID=/,"",id)
                loc[id]=$1"\t"$4"\t"$5"\t"$7
            }
        }
    }
    next
}
NR>FNR && FNR>1 {
    if ($1 in loc)
        print $0, loc[$1]
}
' "$OUTDIR/${PREFIX}.gff" "$OUTDIR/acquired.tsv"

} > "$OUTDIR/final.tsv"

########################################
# STEP 8
########################################
echo "[8/9] Colocalisation"

awk -F'\t' -v OFS='\t' -v D="$COLOC_DIST" '
BEGIN {
    print "amr_gene","metal_gene","contig",
          "amr_start","amr_end","metal_start","metal_end",
          "distance_bp","relationship"
}
NR==1 { next }
{
    contig = $11
    start  = $12
    end    = $13
    type   = $4
    gene   = $3

    if (type == "AMR") {
        nA[contig]++
        amr[contig,nA[contig]] = gene"\t"start"\t"end
    }
    else if (type == "metal") {
        nM[contig]++
        metal[contig,nM[contig]] = gene"\t"start"\t"end
    }
}
END {
    for (c in nM) {
        for (i = 1; i <= nM[c]; i++) {
            split(metal[c,i], m, "\t")
            for (j = 1; j <= nA[c]; j++) {
                split(amr[c,j], a, "\t")

                if (a[3] < m[2]) {
                    dist = m[2] - a[3]
                } else if (m[3] < a[2]) {
                    dist = a[2] - m[3]
                } else {
                    dist = 0
                }

                if (dist <= D) {
                    relationship = (dist == 0 ? "overlapping" : "nearby")
                    print a[1], m[1], c,
                          a[2], a[3],
                          m[2], m[3],
                          dist, relationship
                }
            }
        }
    }
}
' "$OUTDIR/final.tsv" > "$OUTDIR/AMR_metal_colocalised.tsv"

########################################
# STEP 9
########################################
echo "[9/9] Cluster detection"

awk -F'\t' -v OFS='\t' -v D="$COLOC_DIST" '
BEGIN {
print "cluster_id","contig","cluster_start","cluster_end","num_amr","num_metal","genes"
}
NR==1{next}
{
c=$11
s=$12
e=$13
t=$4
g=$3

n[c]++
S[c,n[c]]=s
E[c,n[c]]=e
T[c,n[c]]=t
G[c,n[c]]=g
}
END{
cid=0
for(c in n){
for(i=1;i<=n[c];i++){
for(j=i+1;j<=n[c];j++){
if(S[c,i]>S[c,j]){
tmp=S[c,i];S[c,i]=S[c,j];S[c,j]=tmp
tmp=E[c,i];E[c,i]=E[c,j];E[c,j]=tmp
tmp=T[c,i];T[c,i]=T[c,j];T[c,j]=tmp
tmp=G[c,i];G[c,i]=G[c,j];G[c,j]=tmp
}}}

cs=S[c,1]; ce=E[c,1]
a=0; m=0; genes=G[c,1]

if(T[c,1]=="AMR")a++
if(T[c,1]=="metal")m++

for(i=2;i<=n[c];i++){
gap=S[c,i]-ce

if(gap<=D){
if(E[c,i]>ce)ce=E[c,i]
if(T[c,i]=="AMR")a++
if(T[c,i]=="metal")m++
genes=genes","G[c,i]
}else{
if(a>0 && m>0){
cid++
print "cluster_"cid,c,cs,ce,a,m,genes
}
cs=S[c,i]; ce=E[c,i]
a=(T[c,i]=="AMR")
m=(T[c,i]=="metal")
genes=G[c,i]
}}

if(a>0 && m>0){
cid++
print "cluster_"cid,c,cs,ce,a,m,genes
}
}
}
' "$OUTDIR/final.tsv" > "$OUTDIR/AMR_metal_clusters.tsv"

echo "✔ DONE"
echo "✔ Output: $OUTDIR"